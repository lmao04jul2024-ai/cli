# Chhap App Stamp - Environment Configuration Template
# Copy this file to .env and fill in your values

# HTTP API Base URL
# For physical device testing, use the cloud backend URL
# For iOS simulator on Mac, you can use localhost
BASE_API_URL=https://sastodeal-backend-git.onrender.com

# WebSocket API Base URL
BASE_WS_URL=wss://sastodeal-backend-git.onrender.com/ws

# User ID for this device (replace with actual user ID from backend)
USER_ID=